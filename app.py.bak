                        <span>{:.1f}%</span>
                    </div>
                </div>
                """.format(contributions['image_real'], contributions['image_fake']), unsafe_allow_html=True)
                
                st.markdown("""
                <div class="custom-card">
                    <h4>Domain Trust (15%)</h4>
                    <div style="display: flex; justify-content: space-between;">
                        <span>Real:</span>
                        <span>{:.1f}%</span>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span>Fake:</span>
                        <span>{:.1f}%</span>
                    </div>
                </div>
                """.format(contributions['domain_real'], contributions['domain_fake']), unsafe_allow_html=True)
                
                st.markdown("""
                <div class="custom-card">
                    <h4>LLM Analysis (20%)</h4>
                    <div style="display: flex; justify-content: space-between;">
                        <span>Real:</span>
                        <span>{:.1f}%</span>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span>Fake:</span>
                        <span>{:.1f}%</span>
                    </div>
                </div>
                """.format(contributions['llm_real'], contributions['llm_fake']), unsafe_allow_html=True)
                
                st.markdown('</div>', unsafe_allow_html=True)
            
            # LLM explanation with animation
            st.markdown('<div style="animation: fadeIn 1s ease-in-out;">', unsafe_allow_html=True)
            st.markdown('<h3>LLM Analysis Explanation</h3>', unsafe_allow_html=True)
            
            st.markdown(f"""
            <div class="custom-card" style="border-left: 5px solid #17a2b8;">
                <p>{llm_explanation}</p>
            </div>
            """, unsafe_allow_html=True)
            st.markdown('</div>', unsafe_allow_html=True)
            
            # Related articles with animation
            if related_articles:
                st.markdown('<div style="animation: fadeIn 1.2s ease-in-out;">', unsafe_allow_html=True)
                st.markdown('<h3>Related Articles</h3>', unsafe_allow_html=True)
                
                st.markdown('<div class="custom-card">', unsafe_allow_html=True)
                for article in related_articles:
                    st.markdown(f"""
                    <div style="margin-bottom: 10px; padding: 10px; border-radius: 5px; background-color: #f8f9fa; transition: transform 0.2s ease;">
                        <a href="{article['url']}" target="_blank" style="text-decoration: none; color: #0275d8; font-weight: bold;">
                            {article['title']}
                        </a>
                    </div>
                    """, unsafe_allow_html=True)
                st.markdown('</div>', unsafe_allow_html=True)
                st.markdown('</div>', unsafe_allow_html=True)
            
            # Final verdict with animation
            st.markdown('<div style="animation: fadeIn 1.2s ease-in-out;">', unsafe_allow_html=True)
            st.markdown('<h3>Final Verdict</h3>', unsafe_allow_html=True)
            
            is_fake = combined_results['final_fake_prob'] > combined_results['final_real_prob']
            
            # Create a more visually appealing verdict card
            if is_fake:
                st.markdown("""
                <div class="custom-card" style="border-left: 5px solid #d9534f; animation: slideInUp 0.8s ease-in-out;">
                    <h4 style="color: #d9534f;">This content is likely to be FAKE</h4>
                    <p style="font-weight: bold;">Confidence: {:.1f}%</p>
                    <p>Here's why:</p>
                    <ul>
                        <li>The content may contain sensationalized or exaggerated claims.</li>
                        <li>There might be a lack of credible sources or verifiable facts.</li>
                        <li>The tone and language used may be emotionally charged or biased.</li>
                        <li>The content could be trying to provoke an emotional response.</li>
                        <li>It might lack references or links to original sources.</li>
                    </ul>
                </div>
                """.format(combined_results["final_fake_prob"]), unsafe_allow_html=True)
            else:
                st.markdown("""
                <div class="custom-card" style="border-left: 5px solid #5cb85c; animation: slideInUp 0.8s ease-in-out;">
                    <h4 style="color: #5cb85c;">This content is likely to be REAL</h4>
                    <p style="font-weight: bold;">Confidence: {:.1f}%</p>
                    <p>Here's why:</p>
                    <ul>
                        <li>The content appears to be based on verifiable facts and credible sources.</li>
                        <li>The tone is generally neutral and objective.</li>
                        <li>The content likely presents multiple perspectives on the topic.</li>
                        <li>It cites reputable experts or studies relevant to the topic.</li>
                        <li>The publication has a history of reliable reporting.</li>
                    </ul>
                </div>
                """.format(combined_results["final_real_prob"]), unsafe_allow_html=True)
            
            st.markdown('<div class="custom-card" style="background-color: #f8f9fa; border-left: 5px solid #0275d8;">', unsafe_allow_html=True)
            st.markdown('<p><strong>Note:</strong> Always verify news from reliable sources, regardless of these predictions.</p>', unsafe_allow_html=True)
            st.markdown('</div>', unsafe_allow_html=True)
            
            st.markdown('</div>', unsafe_allow_html=True)
            st.markdown('</div>', unsafe_allow_html=True)  # Close results-container

