        # Create a card for domain info
        st.markdown('<div class="custom-card">', unsafe_allow_html=True)
        
        col1, col2 = st.columns(2)
        
        with col1:
            st.markdown(f"<p><strong>Domain:</strong> {domain_info['domain']}</p>", unsafe_allow_html=True)
            if domain_info['registrar']:
                st.markdown(f"<p><strong>Registrar:</strong> {domain_info['registrar']}</p>", unsafe_allow_html=True)
            if domain_info['creation_date']:
                st.markdown(f"<p><strong>Creation Date:</strong> {domain_info['creation_date'].strftime('%Y-%m-%d')}</p>", unsafe_allow_html=True)
            if domain_info['domain_age']:
                st.markdown(f"<p><strong>Domain Age:</strong> {domain_info['domain_age']} days</p>", unsafe_allow_html=True)
        
        with col2:
            if domain_info['country']:
                st.markdown(f"<p><strong>Country:</strong> {domain_info['country']}</p>", unsafe_allow_html=True)
            if domain_info['state']:
                st.markdown(f"<p><strong>State:</strong> {domain_info['state']}</p>", unsafe_allow_html=True)
            if domain_info['expiration_date']:
                st.markdown(f"<p><strong>Expiration Date:</strong> {domain_info['expiration_date'].strftime('%Y-%m-%d')}</p>", unsafe_allow_html=True)

        # Trust score with visual indicator
        trust_score_percentage = domain_info['trust_score'] * 100
        
        # Create a progress bar style for trust score
        if trust_score_percentage > 70:
            color = "#5cb85c"  # Green for high trust
        elif trust_score_percentage > 40:
            color = "#f0ad4e"  # Yellow for medium trust
        else:
            color = "#d9534f"  # Red for low trust
            
        st.markdown(f"""
        <div style="margin-top: 15px;">
            <p><strong>Trust Score:</strong></p>
            <div style="background-color: #e9ecef; border-radius: 5px; height: 20px; width: 100%;">
                <div style="background-color: {color}; width: {trust_score_percentage}%; height: 100%; border-radius: 5px; 
                     display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">
                    {trust_score_percentage:.2f}%
                </div>
            </div>
        </div>
        """, unsafe_allow_html=True)
        
        st.markdown('</div>', unsafe_allow_html=True)  # Close custom-card
        st.markdown('</div>', unsafe_allow_html=True)  # Close animation div

def create_stacked_bar_chart(combined_results):
    """Create a stacked bar chart showing component contributions."""
    contributions = combined_results['contributions']
    
    chart_data = pd.DataFrame({
        'Category': ['Real', 'Fake'],
        'Article Analysis': [contributions['text_real'], contributions['text_fake']],
        'Image Analysis': [contributions['image_real'], contributions['image_fake']],
        'Domain Trust': [contributions['domain_real'], contributions['domain_fake']],
        'LLM Analysis': [contributions['llm_real'], contributions['llm_fake']]
    })
    
    chart_data_melted = pd.melt(
        chart_data,
        id_vars=['Category'],
        value_vars=['Article Analysis', 'Image Analysis', 'Domain Trust', 'LLM Analysis']
    )
    
    fig = px.bar(
        chart_data_melted,
        x='Category',
        y='value',
        color='variable',
        title='Prediction Breakdown by Component',
        labels={'value': 'Confidence (%)', 'variable': 'Component'},
        color_discrete_map={
            'Article Analysis': '#1f77b4',  # Blue
            'Image Analysis': '#2ca02c',  # Green
            'Domain Trust': '#ff7f0e',    # Orange
            'LLM Analysis': '#d62728'     # Red
        },
        height=400
    )
    
    fig.update_layout(
        barmode='stack',
        xaxis_title="Prediction",
        yaxis_title="Confidence (%)",
        showlegend=True,
        legend_title="Components",
        yaxis_range=[0, 100]
    )
    
    return fig

